{
  "name": "goalplanner-share-mcp",
  "version": "0.1.0",
  "description": "MCP server that crafts RuneLite Goal Planner GPSHARE1: import strings from a structured goal spec.",
  "type": "module",
  "bin": {
    "goalplanner-share-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "gen:bosses": "node scripts/gen-bosses.mjs",
    "gen:items": "node scripts/gen-items.mjs",
    "gen:diaries": "node scripts/gen-diaries.mjs",
    "gen:loadouts": "node scripts/gen-loadouts.mjs",
    "gen:quests": "node scripts/gen-quests.mjs",
    "gen:accounts": "node scripts/gen-accounts.mjs",
    "gen:cas": "node scripts/gen-cas.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25 || ^4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
